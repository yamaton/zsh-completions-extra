function _pixi_task {
    local line state

    function _commands {
        local -a commands
        commands=(
            'add:Add a command to the workspace \[aliases: a\]'
            'remove:Remove a command from the workspace \[aliases: rm\]'
            'alias:Alias another specific command'
            'list:List all tasks in the workspace \[aliases: ls\]'
            'help:Print this message or the help of the given subcommand(s)'
        )
        _describe 'command' commands
    }
 

    _arguments -C \
        {-m,--manifest-path}'[The path to `pixi.toml`, `pyproject.toml`, or the workspace directory]':file:_files \
        {-w,--workspace}'[Name of the workspace]' \
        {-h,--help}'[Display help information]' \
        {-v,--verbose}'[Increase logging verbosity (-v for warnings, -vv for info, -vvv for debug, -vvvv for trace)]' \
        {-q,--quiet}'[Decrease logging verbosity (quiet mode)]' \
        '--color[Whether the log needs to be colored \[env: PIXI_COLOR=\] \[default: auto\] \[possible values: always, never, auto\]]' \
        '--no-progress[Hide all progress bars, always turned on if stderr is not a terminal \[env: PIXI_NO_PROGRESS=\]]' \
        ': :->cmd' \
        '*:: :->subcmd'

    case $state in
    (cmd)
        _commands
        ;;
    (subcmd)
        case $line[1] in
        (add)
            _pixi_task_add
            ;;

        (remove)
            _pixi_task_remove
            ;;

        (alias)
            _pixi_task_alias
            ;;

        (list)
            _pixi_task_list
            ;;

        (help)
            _pixi_task_help
            ;;

        esac
        ;;
     esac

}

